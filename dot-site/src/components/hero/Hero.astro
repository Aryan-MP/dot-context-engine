---
import Button from '../ui/Button.astro';
import AmnesiaTerminal from './AmnesiaTerminal.astro';
import { icons } from '../../data/icons.ts';

const GITHUB_URL = 'https://github.com/aryanp-spektra/dot-context-engine';
const tools = ['claude', 'github', 'cursor'];
---

<section class="dot-grid relative flex min-h-screen items-center overflow-hidden pt-28 pb-20">
  <!-- radial glow -->
  <div
    class="pointer-events-none absolute left-1/2 top-[30%] h-[760px] w-[760px] -translate-x-1/2 -translate-y-1/2 rounded-full"
    style="background: radial-gradient(circle, rgba(124,106,247,0.16) 0%, transparent 62%);"
    aria-hidden="true"
  >
  </div>
  <!-- bottom fade so the grid melts into the page -->
  <div class="pointer-events-none absolute inset-x-0 bottom-0 h-40 bg-gradient-to-b from-transparent to-bg" aria-hidden="true"></div>

  <!-- floating re-explanation counter, top-right -->
  <div
    data-amnesia-counter
    class="absolute right-5 top-24 hidden text-right font-mono text-[11px] leading-tight text-secondary sm:block"
  >
    <div class="text-muted">context re-explanations today</div>
    <div class="text-2xl font-medium text-red"><span data-amnesia-count>2</span></div>
  </div>

  <div class="container-dot relative">
    <div class="mx-auto flex max-w-3xl flex-col items-center text-center">
      <img
        src="/logo-mark-animated.svg"
        alt="Dot logo: a spiral of memory fragments converging into a glowing dot"
        width="120"
        height="120"
        class="reveal mb-6 h-24 w-24 md:h-[120px] md:w-[120px] drop-shadow-[0_0_40px_rgba(124,106,247,0.35)]"
      />

      <div class="reveal mb-7 flex items-center gap-2 rounded-full border border-border bg-elevated/60 px-3.5 py-1.5">
        <span class="h-1.5 w-1.5 animate-blink rounded-full bg-accent"></span>
        <span class="font-mono text-xs tracking-wide text-secondary">
          Open source · Local first · Model agnostic
        </span>
      </div>

      <h1 class="reveal reveal-delay-1 font-serif text-[clamp(48px,7vw,80px)] font-normal leading-[1.04]">
        Your AI tools have<br />
        <span class="text-primary/70">no memory.</span>
      </h1>

      <p class="reveal reveal-delay-2 mt-6 max-w-xl text-lg text-secondary">
        Dot fixes that. One local daemon that gives every AI tool a memory of your
        codebase. Works with Claude, Copilot, Cursor, and any model API.
      </p>

      <div class="reveal reveal-delay-3 mt-8 flex flex-wrap items-center justify-center gap-3.5">
        <Button href="#install" variant="primary" size="md">
          Get started
          <svg viewBox="0 0 24 24" width="18" height="18" set:html={icons.arrowRight} />
        </Button>
        <Button href={GITHUB_URL} target="_blank" rel="noopener noreferrer" variant="ghost" size="md">
          <svg viewBox="0 0 24 24" width="16" height="16" set:html={icons.star} />
          Star on GitHub
        </Button>
      </div>

      <div class="reveal reveal-delay-4 mt-6 flex items-center gap-2.5 text-xs text-muted">
        <span class="flex items-center gap-2">
          {
            tools.map((t) => (
              <svg viewBox="0 0 24 24" width="15" height="15" class="opacity-60" set:html={icons[t]} />
            ))
          }
        </span>
        <span>Works with Claude Code, GitHub Copilot, Cursor, and more</span>
      </div>

      <!-- the centerpiece -->
      <div class="reveal reveal-delay-5 mt-12 w-full max-w-2xl text-left">
        <AmnesiaTerminal />
      </div>
    </div>
  </div>

  <!-- scroll indicator -->
  <a
    href="#pain"
    aria-label="Scroll to content"
    class="absolute bottom-6 left-1/2 -translate-x-1/2 text-muted transition-colors hover:text-secondary"
  >
    <svg viewBox="0 0 24 24" width="22" height="22" class="animate-bounce" set:html={icons.chevronDown} />
  </a>
</section>
