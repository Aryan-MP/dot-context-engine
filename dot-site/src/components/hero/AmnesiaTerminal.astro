---
// The animated amnesia terminal. Logic lives in scripts/amnesia.ts.
---

<div
  data-amnesia
  class="amnesia relative overflow-hidden rounded-xl border border-border bg-elevated transition-all duration-500 ease-[cubic-bezier(0.16,1,0.3,1)]"
>
  <!-- chrome -->
  <div class="flex items-center gap-3 border-b border-border bg-surface px-4 py-2.5">
    <span class="flex gap-1.5" aria-hidden="true">
      <span class="h-3 w-3 rounded-full bg-red/80"></span>
      <span class="h-3 w-3 rounded-full bg-amber/80"></span>
      <span class="h-3 w-3 rounded-full bg-green/80"></span>
    </span>
    <span data-amnesia-title class="font-mono text-xs text-muted">ai-session</span>
    <span data-amnesia-recount class="ml-auto font-mono text-[11px] text-red">re-explained: 2</span>
  </div>

  <!-- body -->
  <div
    data-amnesia-body
    class="amnesia-body h-[340px] overflow-hidden p-5 font-mono text-[13px] leading-[1.8]"
    aria-live="polite"
  >
  </div>

  <!-- overlays -->
  <div class="flash-overlay"></div>
  <div class="pulse-ring"></div>
</div>

<style>
  .amnesia.with-dot {
    border-color: rgba(124, 106, 247, 0.35);
    box-shadow:
      inset 2px 0 0 0 #7c6af7,
      0 0 60px -10px rgba(124, 106, 247, 0.4);
  }
  /* prevent the body from ever growing the layout */
  .amnesia-body {
    scrollbar-width: none;
  }
  .amnesia-body::-webkit-scrollbar {
    display: none;
  }
</style>

<script>
  import { initAmnesia } from '../../scripts/amnesia';
  initAmnesia();
</script>
