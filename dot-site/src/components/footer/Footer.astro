---
const GITHUB = 'https://github.com/aryanp-spektra/dot-context-engine';
const year = new Date().getFullYear();
const cols = [
  {
    head: 'Product',
    links: [
      { label: 'Documentation', href: '/docs' },
      { label: 'Installation', href: '/docs/installation' },
      { label: 'Commands', href: '/docs/cli' },
      { label: 'Changelog', href: '/changelog' },
    ],
  },
  {
    head: 'Source',
    links: [
      { label: 'GitHub', href: GITHUB, ext: true },
      { label: 'Issues', href: GITHUB + '/issues', ext: true },
      { label: 'Contributing', href: GITHUB + '/blob/main/CONTRIBUTING.md', ext: true },
      { label: 'MIT License', href: GITHUB + '/blob/main/LICENSE', ext: true },
    ],
  },
];
---

<footer class="fn-foot">
  <div class="wrap">
    <div class="fn-foot-grid">
      <div class="fn-colophon">
        <a href="/" class="fn-brand">
          <img src="/logo-mark.svg" alt="" width="34" height="34" />
          <span class="fn-word">dot</span>
        </a>
        <p class="fn-tag">Memory for every AI tool you use.</p>
        <p class="fn-note">
          Set in Fraunces &amp; Inter. Kept like a notebook, on purpose.<br />
          Local-first &middot; private &middot; open source.
        </p>
      </div>

      {
        cols.map((c) => (
          <div class="fn-col">
            <h3>{c.head}</h3>
            <ul>
              {c.links.map((l) => (
                <li>
                  <a href={l.href} {...(l.ext ? { target: '_blank', rel: 'noopener' } : {})}>
                    {l.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))
      }

      <div class="fn-col fn-install-col">
        <h3>Install</h3>
        <code>pip install dot-context[ml]</code>
        <p class="fn-os">macOS &middot; Linux &middot; Windows</p>
      </div>
    </div>

    <div class="fn-foot-base">
      <span>&copy; {year} Dot &middot; MIT License</span>
      <span class="fn-foot-hand">your code never leaves your machine ✎</span>
    </div>
  </div>
</footer>

<style>
  .fn-foot {
    border-top: 1px solid var(--rule-strong);
    margin-top: 40px;
    padding: 56px 0 32px;
    background: linear-gradient(var(--paper-2), var(--paper));
  }
  .fn-foot-grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr 1fr 1.2fr;
    gap: 32px;
  }
  .fn-brand {
    display: flex;
    align-items: center;
    gap: 9px;
  }
  .fn-word {
    font-family: var(--serif);
    font-size: 26px;
    font-weight: 600;
  }
  .fn-tag {
    margin-top: 12px;
    color: var(--ink);
    font-size: 15px;
  }
  .fn-note {
    margin-top: 8px;
    color: var(--ink-3);
    font-size: 12.5px;
    line-height: 1.6;
  }
  .fn-col h3 {
    font-family: var(--mono);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--ink-3);
    margin-bottom: 14px;
  }
  .fn-col ul {
    list-style: none;
  }
  .fn-col li + li {
    margin-top: 9px;
  }
  .fn-col a {
    font-size: 14.5px;
    color: var(--ink-2);
    transition: color 0.2s var(--easing);
  }
  .fn-col a:hover {
    color: var(--violet-ink);
  }
  .fn-install-col code {
    display: block;
    font-family: var(--mono);
    font-size: 12.5px;
    background: #1c1916;
    color: #e9e3d6;
    padding: 9px 11px;
    border-radius: 4px;
  }
  .fn-os {
    margin-top: 10px;
    font-size: 12px;
    color: var(--ink-3);
  }
  .fn-foot-base {
    margin-top: 44px;
    padding-top: 18px;
    border-top: 1px solid var(--rule);
    display: flex;
    justify-content: space-between;
    font-size: 13px;
    color: var(--ink-3);
  }
  .fn-foot-hand {
    font-family: var(--hand);
    font-size: 18px;
    color: var(--terra);
  }
  @media (max-width: 760px) {
    .fn-foot-grid {
      grid-template-columns: 1fr 1fr;
    }
    .fn-colophon {
      grid-column: 1 / -1;
    }
    .fn-foot-base {
      flex-direction: column;
      gap: 6px;
    }
  }
</style>
