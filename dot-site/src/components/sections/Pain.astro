---
import SectionLabel from '../ui/SectionLabel.astro';
import { icons } from '../../data/icons.ts';
---

<section id="pain" class="py-32">
  <div class="container-dot">
    <SectionLabel>The problem</SectionLabel>
    <h2 class="reveal reveal-delay-1 mt-5 font-serif text-[clamp(36px,5vw,56px)] font-normal leading-[1.1]">
      You’re the context manager.<br />
      <span class="text-primary/70">You shouldn’t have to be.</span>
    </h2>

    <div class="mt-16 grid grid-cols-1 gap-5 md:grid-cols-3" data-pain>
      <!-- CARD 1 — Re-explanation Tax -->
      <article
        class="reveal group rounded-2xl border border-border bg-elevated p-8 transition-colors duration-300 hover:border-accent/30"
        data-pain-card
      >
        <div class="flex h-36 flex-col justify-center">
          <div class="mb-2 font-mono text-[11px] text-muted">Time explaining context to AI</div>
          <div class="h-3 w-full overflow-hidden rounded-full bg-bg">
            <div
              class="h-full rounded-full bg-gradient-to-r from-amber to-red transition-[width] duration-[1600ms] ease-[cubic-bezier(0.16,1,0.3,1)]"
              style="width:0%"
              data-bar
            >
            </div>
          </div>
          <div class="mt-3 flex items-baseline gap-1.5">
            <span class="font-mono text-2xl font-medium text-red" data-count>0</span>
            <span class="font-mono text-2xl font-medium text-red">%</span>
            <span class="ml-2 text-xs text-muted">~47 min/week per developer</span>
          </div>
        </div>
        <h3 class="mt-6 font-serif text-2xl font-normal">The Re-explanation Tax</h3>
        <p class="mt-2.5 text-sm leading-relaxed text-secondary">
          Every new AI session demands the same explanation. Your stack. Your
          patterns. Your conventions. Multiplied across five tools, ten sessions,
          every single day.
        </p>
      </article>

      <!-- CARD 2 — Tool Amnesia -->
      <article
        class="reveal reveal-delay-1 group rounded-2xl border border-border bg-elevated p-8 transition-colors duration-300 hover:border-accent/30"
      >
        <div class="relative h-36">
          <svg viewBox="0 0 280 150" class="absolute inset-0 h-full w-full" preserveAspectRatio="xMidYMid meet">
            <!-- broken dashed connections -->
            <g stroke="#f87171" stroke-width="1.3" stroke-dasharray="4 7" opacity="0.55" class="animate-[dot-flow-line_2.4s_ease-in-out_infinite]">
              <line x1="78" y1="104" x2="140" y2="44" />
              <line x1="140" y1="44" x2="202" y2="104" />
              <line x1="86" y1="112" x2="194" y2="112" />
            </g>
            <text x="106" y="78" fill="#f87171" font-size="11" opacity="0.8">✕</text>
            <text x="168" y="78" fill="#f87171" font-size="11" opacity="0.8">✕</text>
            <text x="136" y="108" fill="#f87171" font-size="11" opacity="0.8">✕</text>
            <!-- nodes -->
            <g class="animate-[dot-breathe_4s_ease-in-out_infinite]" style="transform-origin:140px 44px">
              <circle cx="140" cy="44" r="20" fill="#18181f" stroke="rgba(255,255,255,0.1)" />
            </g>
            <circle cx="78" cy="104" r="20" fill="#18181f" stroke="rgba(255,255,255,0.1)" />
            <circle cx="202" cy="104" r="20" fill="#18181f" stroke="rgba(255,255,255,0.1)" />
            <!-- 0kb indicators -->
            <text x="140" y="48" text-anchor="middle" fill="#8b8b9e" font-family="JetBrains Mono" font-size="8">0kb</text>
            <text x="78" y="108" text-anchor="middle" fill="#8b8b9e" font-family="JetBrains Mono" font-size="8">0kb</text>
            <text x="202" y="108" text-anchor="middle" fill="#8b8b9e" font-family="JetBrains Mono" font-size="8">0kb</text>
          </svg>
          <!-- tool glyphs layered over nodes -->
          <svg viewBox="0 0 24 24" width="15" height="15" class="absolute left-[calc(50%-7.5px)] top-2 text-secondary" set:html={icons.claude} />
          <svg viewBox="0 0 24 24" width="15" height="15" class="absolute left-[24%] bottom-3 text-secondary" set:html={icons.github} />
          <svg viewBox="0 0 24 24" width="15" height="15" class="absolute right-[24%] bottom-3 text-secondary" set:html={icons.cursor} />
        </div>
        <h3 class="mt-6 font-serif text-2xl font-normal">Tool Amnesia</h3>
        <p class="mt-2.5 text-sm leading-relaxed text-secondary">
          Every AI tool lives in its own silo. What Claude learned this morning
          means nothing to Copilot this afternoon. You’re the only memory
          connecting them.
        </p>
      </article>

      <!-- CARD 3 — The Lost Decision -->
      <article
        class="reveal reveal-delay-2 group rounded-2xl border border-border bg-elevated p-8 transition-colors duration-300 hover:border-accent/30"
      >
        <div class="relative h-36 overflow-hidden">
          <!-- git log -->
          <div class="absolute left-4 top-0 h-full w-px bg-border"></div>
          <div class="flex h-full flex-col justify-center gap-2.5 pl-2">
            <div class="flex items-center gap-3"><span class="h-2.5 w-2.5 rounded-full bg-muted"></span></div>
            <div class="flex items-center gap-3"><span class="h-2.5 w-2.5 rounded-full bg-amber shadow-[0_0_10px_rgba(251,191,36,0.6)]"></span><span class="font-mono text-[10px] text-muted">a1b2c3 · refactor checkout</span></div>
            <div class="flex items-center gap-3"><span class="h-2.5 w-2.5 rounded-full bg-muted"></span></div>
            <div class="flex items-center gap-3"><span class="h-2.5 w-2.5 rounded-full bg-amber shadow-[0_0_10px_rgba(251,191,36,0.6)]"></span><span class="font-mono text-[10px] text-muted">d4e5f6 · event sourcing</span></div>
            <div class="flex items-center gap-3"><span class="h-2.5 w-2.5 rounded-full bg-muted"></span></div>
          </div>
          <!-- speech bubbles, surface on hover -->
          <div class="pointer-events-none absolute inset-0 flex flex-col items-end justify-center gap-1.5 pr-1 opacity-0 transition-opacity duration-500 group-hover:opacity-100">
            <span class="rounded-lg rounded-br-none border border-border bg-surface px-2.5 py-1 font-mono text-[10px] text-secondary">Why did we choose this approach?</span>
            <span class="rounded-lg rounded-tr-none border border-red/30 bg-red/10 px-2.5 py-1 font-mono text-[10px] text-red">I don’t have that context.</span>
          </div>
        </div>
        <h3 class="mt-6 font-serif text-2xl font-normal">The Lost Decision</h3>
        <p class="mt-2.5 text-sm leading-relaxed text-secondary">
          Your codebase shows what was built. It never shows why. Every
          architectural decision, every rejected approach, every hard-won lesson —
          gone the moment the chat closes.
        </p>
      </article>
    </div>
  </div>
</section>

<script>
  import { onceInView } from '../../scripts/intersection';

  const card = document.querySelector('[data-pain-card]');
  if (card) {
    onceInView(card, () => {
      const bar = card.querySelector<HTMLElement>('[data-bar]');
      const num = card.querySelector<HTMLElement>('[data-count]');
      if (bar) bar.style.width = '73%';
      if (num) {
        const target = 73;
        const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        if (reduced) {
          num.textContent = String(target);
        } else {
          const start = performance.now();
          const dur = 1500;
          const step = (now: number) => {
            const t = Math.min(1, (now - start) / dur);
            num.textContent = String(Math.round(target * (1 - Math.pow(1 - t, 3))));
            if (t < 1) requestAnimationFrame(step);
          };
          requestAnimationFrame(step);
        }
      }
    });
  }
</script>
