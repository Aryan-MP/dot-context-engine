---
const GITHUB = 'https://github.com/aryanp-spektra/dot-context-engine';
const links = [
  { label: 'Docs', href: '/docs' },
  { label: 'Changelog', href: '/changelog' },
  { label: 'GitHub', href: GITHUB, external: true },
];
const path = Astro.url.pathname;
---

<header class="fn-nav">
  <div class="wrap fn-nav-inner">
    <a href="/" class="fn-brand" aria-label="Dot home">
      <img src="/logo-mark.svg" alt="" width="30" height="30" />
      <span class="fn-word">dot</span>
      <span class="fn-edition">field&nbsp;notes</span>
    </a>

    <nav class="fn-links" aria-label="Primary">
      {
        links.map((l) => (
          <a
            href={l.href}
            class:list={['fn-link', { current: path.startsWith(l.href) && l.href !== '/' }]}
            {...(l.external ? { target: '_blank', rel: 'noopener' } : {})}
          >
            {l.label}
          </a>
        ))
      }
      <a href="/docs/installation" class="btn btn-primary fn-install">Install</a>
    </nav>

    <button class="fn-burger" id="fn-burger" aria-label="Menu" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
  </div>

  <div class="fn-drawer" id="fn-drawer">
    {
      links.map((l) => (
        <a href={l.href} {...(l.external ? { target: '_blank', rel: 'noopener' } : {})}>
          {l.label}
        </a>
      ))
    }
    <a href="/docs/installation" class="btn btn-primary" style="margin-top:8px;">Install</a>
  </div>
</header>

<style>
  .fn-nav {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(244, 239, 228, 0.82);
    backdrop-filter: blur(8px);
    border-bottom: 1px solid var(--rule);
  }
  .fn-nav-inner {
    display: flex;
    align-items: center;
    gap: 24px;
    padding-top: 14px;
    padding-bottom: 14px;
  }
  .fn-brand {
    display: flex;
    align-items: baseline;
    gap: 9px;
  }
  .fn-brand img {
    align-self: center;
  }
  .fn-word {
    font-family: var(--serif);
    font-size: 24px;
    font-weight: 600;
    letter-spacing: -0.02em;
  }
  .fn-edition {
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--ink-3);
    border-left: 1px solid var(--rule-strong);
    padding-left: 9px;
  }
  .fn-links {
    margin-left: auto;
    display: flex;
    align-items: center;
    gap: 26px;
  }
  .fn-link {
    font-size: 15px;
    color: var(--ink-2);
    transition: color 0.2s var(--easing);
    position: relative;
  }
  .fn-link:hover,
  .fn-link.current {
    color: var(--ink);
  }
  .fn-link.current::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: -6px;
    height: 2px;
    background: var(--violet);
  }
  .fn-install {
    padding: 8px 16px;
    font-size: 14px;
  }
  .fn-burger {
    display: none;
    margin-left: auto;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 6px;
  }
  .fn-burger span {
    width: 22px;
    height: 2px;
    background: var(--ink);
    display: block;
  }
  .fn-drawer {
    display: none;
    flex-direction: column;
    gap: 4px;
    padding: 8px 28px 18px;
    border-bottom: 1px solid var(--rule);
  }
  .fn-drawer.open {
    display: flex;
  }
  /* the drawer is a mobile affordance only */
  @media (min-width: 721px) {
    .fn-drawer {
      display: none !important;
    }
  }
  .fn-drawer a:not(.btn) {
    padding: 10px 0;
    color: var(--ink-2);
    border-bottom: 1px solid var(--rule);
  }
  @media (max-width: 720px) {
    .fn-links {
      display: none;
    }
    .fn-burger {
      display: flex;
    }
    .fn-edition {
      display: none;
    }
  }
</style>

<script>
  const burger = document.getElementById('fn-burger');
  const drawer = document.getElementById('fn-drawer');
  burger?.addEventListener('click', () => {
    const open = drawer?.classList.toggle('open');
    burger.setAttribute('aria-expanded', String(!!open));
  });
</script>
