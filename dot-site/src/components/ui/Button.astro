---
export interface Props {
  variant?: 'primary' | 'ghost' | 'outline';
  size?: 'sm' | 'md' | 'lg';
  href?: string;
  type?: 'button' | 'submit';
  class?: string;
  target?: string;
  rel?: string;
  id?: string;
}

const {
  variant = 'primary',
  size = 'md',
  href,
  type = 'button',
  class: extra = '',
  target,
  rel,
  id,
} = Astro.props;

const base =
  'inline-flex items-center justify-center gap-2 font-medium rounded-lg transition-all duration-200 ease-[cubic-bezier(0.16,1,0.3,1)] whitespace-nowrap select-none focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent/60 active:scale-[0.98]';

const variants: Record<string, string> = {
  primary:
    'bg-accent text-white shadow-[0_8px_30px_-8px_rgba(124,106,247,0.55)] hover:bg-accent/90 hover:shadow-[0_14px_40px_-8px_rgba(124,106,247,0.65)] hover:-translate-y-0.5',
  ghost:
    'border border-border text-primary hover:border-accent/50 hover:bg-accent-glow',
  outline:
    'border border-accent/40 text-accent hover:bg-accent-glow hover:border-accent/70',
};

const sizes: Record<string, string> = {
  sm: 'text-sm px-3.5 py-2',
  md: 'text-[15px] px-6 py-3',
  lg: 'text-base px-8 py-4',
};

const cls = `${base} ${variants[variant]} ${sizes[size]} ${extra}`;
---

{
  href ? (
    <a href={href} class={cls} target={target} rel={rel} id={id}>
      <slot />
    </a>
  ) : (
    <button type={type} class={cls} id={id}>
      <slot />
    </button>
  )
}
