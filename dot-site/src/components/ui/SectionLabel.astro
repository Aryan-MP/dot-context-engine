---
export interface Props {
  class?: string;
}
const { class: extra = '' } = Astro.props;
---

<div class={`reveal flex items-center gap-2.5 ${extra}`}>
  <span class="h-px w-6 bg-accent"></span>
  <span class="font-mono text-xs uppercase tracking-[0.2em] text-accent">
    <slot />
  </span>
</div>
