---
import Page from '../layouts/Page.astro';

const GITHUB = 'https://github.com/aryanp-spektra/dot-context-engine';

const features = [
  {
    no: 'a',
    title: 'Semantic code search',
    body: 'Ask in plain language. Dot finds the function that charges a card even when it never says “charge”, using local embeddings over AST-aware chunks.',
    rot: '-1.4deg',
  },
  {
    no: 'b',
    title: 'Decisions, mined',
    body: 'Every “chose X over Y because…” buried in your git history and code comments is surfaced, dated, and made queryable. The why, finally kept.',
    rot: '1.1deg',
  },
  {
    no: 'c',
    title: 'Local &amp; private',
    body: 'Embeddings run on your CPU. Storage is SQLite on your disk. The only network call ever is a one-time model download. Your code never leaves.',
    rot: '-0.8deg',
  },
  {
    no: 'd',
    title: 'Every tool, one memory',
    body: 'Claude Code, Copilot, Cursor, or a curl one-liner all read the same memory through a local API. Switch tools without re-explaining a thing.',
    rot: '1.5deg',
  },
  {
    no: 'e',
    title: 'Team memory in git',
    body: 'Share a decision and it travels in a committed file. Teammates pull, and their Dot imports it automatically. No server, no account.',
    rot: '-1.1deg',
  },
  {
    no: 'f',
    title: 'Recency that matters',
    body: 'What you touched this morning outranks a stale match. Context is scored on similarity, proximity, recency and edit frequency, then budgeted.',
    rot: '0.9deg',
  },
];

const tools = ['Claude Code', 'GitHub Copilot', 'Cursor', 'Neovim', 'any REST client'];
---

<Page
  title="Dot - Memory for every AI tool you use"
  description="Open-source local daemon that gives Claude Code, GitHub Copilot, Cursor, and any AI tool a memory of your codebase. Private. Local. Model-agnostic."
>
  <!-- ============ HERO ============ -->
  <section class="hero">
    <div class="wrap hero-grid">
      <div class="hero-copy">
        <span class="stamp reveal">open source · local-first · model-agnostic</span>
        <h1 class="reveal d1">
          Your AI tools<br />forget. Dot
          <span class="inked"
            >remembers<svg viewBox="0 0 300 12" preserveAspectRatio="none"
              ><path d="M3 8 C 70 2, 150 2, 297 6" /></svg
            ></span
          >.
        </h1>
        <p class="hero-sub reveal d2">
          One small daemon runs beside your code, learns it, captures the decisions
          behind it, and hands the right context to whatever AI tool you are using.
          Stop re-explaining your codebase to a machine that forgets.
        </p>
        <div class="hero-cta reveal d3">
          <a href="/docs/installation" class="btn btn-primary">Get started →</a>
          <a href={GITHUB} target="_blank" rel="noopener" class="btn btn-ghost">Read the source</a>
        </div>
        <p class="hero-trust reveal d4">
          Works with {tools.slice(0, 4).join(', ')}, and anything that speaks HTTP.
        </p>
      </div>

      <!-- the "memory desk": a catalog card that recalls context -->
      <div class="hero-desk reveal d2">
        <div class="pins">
          <span class="pin" style="--rot:-4deg">codebase</span>
          <span class="pin" style="--rot:3deg">git history</span>
          <span class="pin" style="--rot:-2deg">decisions</span>
        </div>

        <article class="catalog fn-float" style="--rot:-1.2deg">
          <header>
            <span class="catalog-no">MEMORY CARD No. 0041</span>
            <span class="catalog-file">payments/limiter.ts</span>
          </header>
          <div class="catalog-body" data-type-lines>
            <span data-line data-pre="recall ▸ ">"how should I rate-limit payments?"</span>
            <span data-line data-cls="dim">- assembling from 12 chunks, 2 decisions -</span>
            <span data-line data-cls="hit">▸ auth/limiter.ts &nbsp;reuse this pattern</span>
            <span data-line data-cls="hit">▸ decision: Redis over Memcached (TTL)</span>
            <span data-line data-cls="hit">▸ decision: payments SLA is stricter</span>
            <span data-line data-cls="ok">✓ context ready · 3,240 tokens · 67ms</span>
          </div>
          <div class="catalog-stamp">recalled<br />locally</div>
        </article>

        <p class="margin-note hero-margin">↳ no re-explaining.<br />every tool, same memory.</p>
      </div>
    </div>
  </section>

  <!-- ============ THE PROBLEM (ledger) ============ -->
  <section class="band">
    <div class="wrap">
      <div class="sec-mark reveal">the problem<span class="rule"></span>01</div>
      <h2 class="band-head reveal d1">
        You became the<br />context <em>manager.</em>
      </h2>
      <div class="ledger reveal d2">
        <div class="ledger-row">
          <span class="ledger-when">every new chat</span>
          <span class="ledger-what">You paste your stack, your conventions, your file layout. Again.</span>
          <span class="ledger-cost">~minutes</span>
        </div>
        <div class="ledger-row">
          <span class="ledger-when">every tool switch</span>
          <span class="ledger-what">What Claude learned this morning, Copilot has no idea about this afternoon.</span>
          <span class="ledger-cost">lost</span>
        </div>
        <div class="ledger-row">
          <span class="ledger-when">every few months</span>
          <span class="ledger-what">“Why did we build it this way?” The person who knew has moved on.</span>
          <span class="ledger-cost">gone</span>
        </div>
      </div>
      <p class="margin-note ledger-margin">you shouldn't have to be the memory.</p>
    </div>
  </section>

  <!-- ============ HOW IT WORKS ============ -->
  <section class="band">
    <div class="wrap">
      <div class="sec-mark reveal">how it works<span class="rule"></span>02</div>
      <div class="steps">
        <div class="step reveal">
          <span class="step-no serif">i.</span>
          <h3 class="serif">It reads your codebase</h3>
          <p>
            Tree-sitter parses your code into whole functions and classes, embeds each
            one locally, and watches for changes. A real map, not a text dump.
          </p>
        </div>
        <div class="step reveal d1">
          <span class="step-no serif">ii.</span>
          <h3 class="serif">It remembers the why</h3>
          <p>
            Commit messages, comments and (optionally) your AI chats are mined for
            decisions and kept with a gentle forgetting curve: used memories stay warm.
          </p>
        </div>
        <div class="step reveal d2">
          <span class="step-no serif">iii.</span>
          <h3 class="serif">It recalls on demand</h3>
          <p>
            Any tool asks the local API a question; Dot ranks everything it knows and
            returns a budgeted, formatted answer in under a tenth of a second.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ WHAT DOT KNOWS (index cards) ============ -->
  <section class="band">
    <div class="wrap">
      <div class="sec-mark reveal">in the box<span class="rule"></span>03</div>
      <h2 class="band-head reveal d1">What Dot keeps<br />for you.</h2>
      <div class="cards-grid">
        {
          features.map((f, i) => (
            <article class={`feat card fn-file`} style={`--rot:${f.rot}`} data-file-delay={i * 90}>
              <span class="feat-tab">{f.no}</span>
              <h3 class="serif" set:html={f.title} />
              <p set:html={f.body} />
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ============ WORKS WITH (filed tabs) ============ -->
  <section class="band">
    <div class="wrap">
      <div class="sec-mark reveal">filed under<span class="rule"></span>04</div>
      <h2 class="band-head reveal d1">Works with the tools<br />you already open.</h2>
      <div class="tabs reveal d2">
        {tools.map((t) => <span class="filed-tab">{t}</span>)}
      </div>
      <p class="band-sub reveal d3">
        Claude Code gets native MCP tools. Copilot reads injected context in VS Code.
        Cursor and everything else use one REST endpoint on <code>localhost:7337</code>.
        <a href="/docs/integrations" class="inline-link">See integration docs →</a>
      </p>
    </div>
  </section>

  <!-- ============ INSTALL ============ -->
  <section class="band">
    <div class="wrap install-wrap">
      <div class="sec-mark reveal" style="justify-content:center">two minutes<span class="rule"></span>05</div>
      <h2 class="band-head center reveal d1">Set it down once.<br />It remembers from then on.</h2>
      <div class="paper-term reveal d2">
        <div class="paper-term-bar">
          <span></span><span></span><span></span>
          <em>terminal</em>
        </div>
        <pre><code><span class="c"># install with local embeddings</span>
<span class="p">$</span> pip install dot-context[ml]

<span class="c"># point it at any project</span>
<span class="p">$</span> cd your-project
<span class="p">$</span> dot init
<span class="p">$</span> dot daemon start

<span class="ok">● dot is running - every AI tool now has memory.</span></code></pre>
      </div>
      <div class="install-cta reveal d3">
        <a href="/docs/quickstart" class="btn btn-primary">Quick start guide →</a>
        <a href="/docs" class="btn btn-ghost">Browse the docs</a>
      </div>
    </div>
  </section>
</Page>

<style>
  .hero {
    padding: 64px 0 40px;
  }
  .hero-grid {
    display: grid;
    grid-template-columns: 1.05fr 0.95fr;
    gap: 48px;
    align-items: center;
  }
  .hero-copy h1 {
    font-size: clamp(40px, 6vw, 72px);
    margin: 20px 0 22px;
  }
  .hero-sub {
    font-size: 18px;
    color: var(--ink-2);
    max-width: 30em;
  }
  .hero-cta {
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
    margin-top: 28px;
  }
  .hero-trust {
    margin-top: 20px;
    font-size: 13.5px;
    color: var(--ink-3);
  }

  /* desk */
  .hero-copy {
    min-width: 0;
  }
  .hero-desk {
    position: relative;
    min-width: 0;
  }
  .pins {
    display: flex;
    gap: 10px;
    justify-content: center;
    margin-bottom: 16px;
  }
  .pin {
    font-family: var(--mono);
    font-size: 11px;
    background: var(--paper-2);
    border: 1px solid var(--paper-edge);
    border-top: 3px solid var(--violet);
    border-radius: 0 0 4px 4px;
    padding: 6px 11px;
    transform: rotate(var(--rot));
    color: var(--ink-2);
    box-shadow: 0 6px 14px -12px rgba(31, 27, 22, 0.5);
  }
  .catalog {
    position: relative;
    max-width: 100%;
    overflow: hidden;
    background: var(--paper-2);
    border: 1px solid var(--paper-edge);
    border-radius: 5px;
    padding: 18px 18px 16px;
    box-shadow:
      0 1px 0 rgba(255, 255, 255, 0.7) inset,
      0 24px 48px -28px rgba(31, 27, 22, 0.55);
    /* a faint ruled line down the left like an index card */
    background-image: linear-gradient(90deg, transparent 38px, rgba(200, 97, 47, 0.25) 39px, transparent 40px);
  }
  .catalog header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    border-bottom: 1px solid var(--rule);
    padding-bottom: 8px;
    margin-bottom: 12px;
    padding-left: 50px;
  }
  .catalog-no {
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.1em;
    color: var(--ink-3);
  }
  .catalog-file {
    font-family: var(--mono);
    font-size: 12px;
    color: var(--violet-ink);
  }
  .catalog-body {
    font-family: var(--mono);
    font-size: 12.5px;
    line-height: 1.9;
    padding-left: 50px;
    min-height: 168px;
    overflow-x: auto;
  }
  .catalog-body span {
    display: block;
    white-space: nowrap;
    overflow: hidden;
  }
  .catalog-body .dim {
    color: var(--ink-3);
  }
  .catalog-body .hit {
    color: var(--ink);
  }
  .catalog-body .ok {
    color: var(--green);
  }
  .catalog-stamp {
    position: absolute;
    right: 14px;
    bottom: 14px;
    font-family: var(--mono);
    font-size: 10px;
    line-height: 1.2;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--terra);
    border: 1.5px solid var(--terra);
    border-radius: 4px;
    padding: 5px 8px;
    transform: rotate(-8deg);
    opacity: 0.85;
    text-align: center;
  }
  .hero-margin {
    margin-top: 22px;
    text-align: right;
  }

  /* bands */
  .band {
    padding: 56px 0;
  }
  .band-head {
    font-size: clamp(30px, 4.4vw, 50px);
    margin-bottom: 28px;
  }
  .band-head.center {
    text-align: center;
  }
  .band-sub {
    margin-top: 22px;
    color: var(--ink-2);
    max-width: 40em;
    font-size: 16px;
  }
  .band-sub code {
    font-family: var(--mono);
    font-size: 0.85em;
    background: var(--paper-2);
    border: 1px solid var(--paper-edge);
    border-radius: 3px;
    padding: 0.1em 0.4em;
  }
  .inline-link {
    color: var(--violet-ink);
    text-decoration: underline;
    text-underline-offset: 2px;
    white-space: nowrap;
  }

  /* ledger */
  .ledger {
    border-top: 2px solid var(--ink);
  }
  .ledger-row {
    display: grid;
    grid-template-columns: 160px 1fr 90px;
    gap: 20px;
    padding: 16px 4px;
    border-bottom: 1px solid var(--rule);
    align-items: baseline;
  }
  .ledger-when {
    font-family: var(--mono);
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--ink-3);
  }
  .ledger-what {
    font-size: 17px;
  }
  .ledger-cost {
    font-family: var(--hand);
    font-size: 22px;
    color: var(--terra);
    text-align: right;
  }
  .ledger-margin {
    margin-top: 24px;
  }

  /* steps */
  .steps {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 28px;
  }
  .step {
    border-top: 2px solid var(--violet);
    padding-top: 18px;
  }
  .step-no {
    font-size: 30px;
    color: var(--violet-ink);
  }
  .step h3 {
    font-size: 23px;
    margin: 6px 0 10px;
  }
  .step p {
    color: var(--ink-2);
    font-size: 15.5px;
  }

  /* feature cards */
  .cards-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }
  .feat {
    position: relative;
    padding: 26px 22px 22px;
    transition: transform 0.25s var(--easing), box-shadow 0.25s var(--easing);
  }
  .feat:hover {
    transform: rotate(0deg) translateY(-3px) !important;
    box-shadow: 0 18px 34px -22px rgba(31, 27, 22, 0.55);
  }
  .feat-tab {
    position: absolute;
    top: -10px;
    left: 18px;
    width: 26px;
    height: 26px;
    display: grid;
    place-items: center;
    font-family: var(--mono);
    font-size: 12px;
    background: var(--violet);
    color: #fff;
    border-radius: 50%;
  }
  .feat h3 {
    font-size: 21px;
    margin-bottom: 8px;
  }
  .feat p {
    color: var(--ink-2);
    font-size: 14.5px;
    line-height: 1.6;
  }

  /* filed tabs */
  .tabs {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
  }
  .filed-tab {
    font-family: var(--mono);
    font-size: 13px;
    padding: 9px 16px;
    background: var(--paper-2);
    border: 1px solid var(--paper-edge);
    border-bottom: 3px solid var(--violet);
    border-radius: 4px 4px 0 0;
    color: var(--ink);
  }

  /* install */
  .install-wrap {
    max-width: 760px;
  }
  .paper-term {
    border-radius: 7px;
    overflow: hidden;
    border: 1px solid #2c2822;
    box-shadow: 0 26px 50px -30px rgba(31, 27, 22, 0.6);
  }
  .paper-term-bar {
    background: #2a2620;
    display: flex;
    align-items: center;
    gap: 7px;
    padding: 10px 14px;
  }
  .paper-term-bar span {
    width: 11px;
    height: 11px;
    border-radius: 50%;
    background: #4a443b;
  }
  .paper-term-bar em {
    margin-left: auto;
    font-family: var(--mono);
    font-style: normal;
    font-size: 11px;
    color: #8a8377;
  }
  .paper-term pre {
    margin: 0;
    background: #1c1916;
    color: #e9e3d6;
    font-family: var(--mono);
    font-size: 14px;
    line-height: 1.9;
    padding: 20px 22px;
    overflow-x: auto;
  }
  .paper-term .c {
    color: #8a8377;
  }
  .paper-term .p {
    color: var(--terra);
  }
  .paper-term .ok {
    color: #7fc98e;
  }
  .install-cta {
    display: flex;
    gap: 14px;
    justify-content: center;
    margin-top: 26px;
    flex-wrap: wrap;
  }

  @media (max-width: 860px) {
    .hero-grid {
      grid-template-columns: 1fr;
    }
    .steps,
    .cards-grid {
      grid-template-columns: 1fr;
    }
    .ledger-row {
      grid-template-columns: 1fr;
      gap: 4px;
    }
    .ledger-cost {
      text-align: left;
    }
    .hero-copy h1 {
      font-size: clamp(34px, 9vw, 52px);
    }
    .hero-margin {
      text-align: left;
    }
    .catalog-body {
      font-size: 11.5px;
      padding-left: 44px;
    }
  }
</style>

<script>
  // Ink underline draw + feature-card filing + hero catalog typewriter.
  const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const io = new IntersectionObserver(
    (entries) => {
      for (const e of entries) {
        if (!e.isIntersecting) continue;
        const el = e.target as HTMLElement;
        if (el.classList.contains('inked')) el.classList.add('drawn');
        if (el.classList.contains('fn-file')) {
          const delay = Number(el.dataset.fileDelay || 0);
          setTimeout(() => el.classList.add('go'), delay);
        }
        if (el.hasAttribute('data-type-lines')) typeCatalog(el);
        io.unobserve(el);
      }
    },
    { threshold: 0.25 },
  );
  document
    .querySelectorAll('.inked, .fn-file, [data-type-lines]')
    .forEach((el) => io.observe(el));

  function typeCatalog(box: HTMLElement) {
    const lines = Array.from(box.querySelectorAll<HTMLElement>('[data-line]'));
    lines.forEach((l) => {
      l.dataset.full = (l.dataset.pre || '') + l.textContent;
      l.textContent = '';
      l.style.visibility = 'hidden';
      if (l.dataset.cls) l.classList.add(l.dataset.cls);
    });
    if (reduced) {
      lines.forEach((l) => {
        l.textContent = l.dataset.full || '';
        l.style.visibility = 'visible';
      });
      return;
    }
    let i = 0;
    const next = () => {
      if (i >= lines.length) return;
      const l = lines[i];
      l.style.visibility = 'visible';
      const full = l.dataset.full || '';
      let c = 0;
      const caret = document.createElement('span');
      caret.className = 'fn-caret';
      const type = () => {
        l.textContent = full.slice(0, c);
        l.appendChild(caret);
        if (c++ <= full.length) {
          setTimeout(type, 14);
        } else {
          caret.remove();
          i++;
          setTimeout(next, 220);
        }
      };
      type();
    };
    next();
  }
</script>
