---
import Page from '../layouts/Page.astro';

const releases = [
  {
    version: 'v0.1.0-alpha',
    date: '2026',
    tag: 'first public release',
    items: [
      'Core daemon: filesystem watcher, AST-aware chunking, local embeddings, SQLite + ChromaDB storage.',
      'Decision mining from git history, code comments, and (opt-in) Claude Code conversations.',
      'Context assembly with multi-signal ranking (similarity, proximity, recency, edit frequency).',
      'MCP server for Claude Code, plus the VS Code extension and a universal REST API.',
      'Git-native team memory sharing via dot-memories.jsonl.',
      'dot doctor diagnostics and cross-platform daemon lifecycle.',
    ],
  },
];
---

<Page title="Changelog — Dot" description="Release notes and version history for Dot.">
  <section class="cl">
    <div class="wrap">
      <div class="sec-mark reveal">record of changes<span class="rule"></span>log</div>
      <h1 class="cl-title serif reveal d1">What's new in Dot.</h1>
      <p class="cl-sub reveal d2">
        Every release, kept in the open. Follow along on
        <a href="https://github.com/aryanp-spektra/dot-context-engine/releases" target="_blank" rel="noopener">GitHub releases</a>.
      </p>

      <div class="cl-list">
        {
          releases.map((r) => (
            <article class="cl-entry reveal">
              <div class="cl-meta">
                <span class="cl-ver serif">{r.version}</span>
                <span class="stamp">{r.tag}</span>
                <span class="cl-date">{r.date}</span>
              </div>
              <ul>
                {r.items.map((it) => (
                  <li>{it}</li>
                ))}
              </ul>
            </article>
          ))
        }
      </div>
    </div>
  </section>
</Page>

<style>
  .cl {
    padding: 56px 0 24px;
  }
  .cl-title {
    font-size: clamp(34px, 5vw, 52px);
    margin: 10px 0 14px;
  }
  .cl-sub {
    color: var(--ink-2);
    margin-bottom: 40px;
  }
  .cl-sub a {
    color: var(--violet-ink);
    text-decoration: underline;
  }
  .cl-list {
    border-left: 2px solid var(--violet);
    padding-left: 28px;
  }
  .cl-entry {
    position: relative;
  }
  .cl-entry::before {
    content: '';
    position: absolute;
    left: -35px;
    top: 6px;
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: var(--violet);
    border: 3px solid var(--paper);
  }
  .cl-meta {
    display: flex;
    align-items: center;
    gap: 14px;
    flex-wrap: wrap;
    margin-bottom: 14px;
  }
  .cl-ver {
    font-size: 26px;
  }
  .cl-date {
    font-family: var(--mono);
    font-size: 12px;
    color: var(--ink-3);
  }
  .cl-entry ul {
    list-style: none;
  }
  .cl-entry li {
    position: relative;
    padding-left: 20px;
    color: var(--ink-2);
    font-size: 15.5px;
    margin-bottom: 9px;
  }
  .cl-entry li::before {
    content: '✎';
    position: absolute;
    left: 0;
    color: var(--terra);
    font-size: 13px;
  }
</style>
