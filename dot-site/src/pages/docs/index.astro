---
import Page from '../../layouts/Page.astro';
import SectionLabel from '../../components/ui/SectionLabel.astro';
import Button from '../../components/ui/Button.astro';
import Install from '../../components/sections/Install.astro';

const GITHUB_URL = 'https://github.com/aryanp-spektra/dot-context-engine';

const quickLinks = [
  { title: 'README', desc: 'Overview, architecture, and the full CLI reference.', href: GITHUB_URL + '#readme' },
  { title: 'Getting started', desc: 'Install, init, and wire Dot into your tools.', href: GITHUB_URL + '/blob/main/docs/getting-started.md' },
  { title: 'Architecture', desc: 'How indexing, ranking, and assembly work.', href: GITHUB_URL + '/blob/main/docs/architecture.md' },
  { title: 'Integrations', desc: 'Claude Code, Copilot, Cursor, and the REST API.', href: GITHUB_URL + '/blob/main/docs/integrations.md' },
];
---

<Page title="Docs — Dot" description="Documentation for Dot, the local-first AI context memory daemon.">
  <section class="dot-grid border-b border-border pb-20 pt-36">
    <div class="container-dot">
      <SectionLabel>Documentation</SectionLabel>
      <h1 class="reveal reveal-delay-1 mt-5 max-w-2xl font-serif text-[clamp(40px,5.5vw,64px)] font-normal leading-[1.08]">
        Documentation is<br /><span class="text-primary/70">coming soon.</span>
      </h1>
      <p class="reveal reveal-delay-2 mt-6 max-w-xl text-lg text-secondary">
        We’re building a full docs site here. In the meantime, everything you need
        lives in the GitHub repository — fully written, fully open source.
      </p>
      <div class="reveal reveal-delay-3 mt-8">
        <Button href={GITHUB_URL} target="_blank" rel="noopener noreferrer" variant="primary">
          Read the docs on GitHub
        </Button>
      </div>

      <div class="mt-14 grid grid-cols-1 gap-4 sm:grid-cols-2">
        {
          quickLinks.map((l, i) => (
            <a
              href={l.href}
              target="_blank"
              rel="noopener noreferrer"
              class={`reveal reveal-delay-${i + 1} group rounded-2xl border border-border bg-elevated p-6 transition-all duration-300 hover:-translate-y-1 hover:border-accent/40`}
            >
              <h3 class="text-lg font-semibold tracking-tight">{l.title}</h3>
              <p class="mt-1.5 text-sm text-secondary">{l.desc}</p>
              <span class="mt-3 inline-block font-mono text-xs text-accent">Open →</span>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <Install />
</Page>
