---
import Base from './Base.astro';
import Nav from '../components/nav/Nav.astro';
import Footer from '../components/footer/Footer.astro';

// Markdown pages pass `frontmatter` and `headings`; .astro pages pass props.
const { frontmatter, headings = [] } = Astro.props as {
  frontmatter?: { title?: string; description?: string };
  headings?: { depth: number; slug: string; text: string }[];
};
const title = frontmatter?.title ?? (Astro.props as any).title ?? 'Documentation';
const description =
  frontmatter?.description ?? (Astro.props as any).description ?? 'Dot documentation.';

const nav = [
  {
    group: 'Start here',
    items: [
      { label: 'Overview', href: '/docs' },
      { label: 'Installation', href: '/docs/installation' },
      { label: 'Quick start', href: '/docs/quickstart' },
    ],
  },
  {
    group: 'Reference',
    items: [
      { label: 'Commands (CLI)', href: '/docs/cli' },
      { label: 'Configuration', href: '/docs/configuration' },
      { label: 'Integrations', href: '/docs/integrations' },
    ],
  },
  {
    group: 'More',
    items: [
      { label: 'FAQ', href: '/docs/faq' },
      { label: 'Changelog', href: '/changelog' },
    ],
  },
];

const path = Astro.url.pathname.replace(/\/$/, '') || '/docs';
const toc = headings.filter((h) => h.depth === 2 || h.depth === 3);
---

<Base title={`${title} - Dot Docs`} description={description}>
  <Nav />
  <main id="main" class="docs">
    <div class="docs-wrap">
      <!-- sidebar -->
      <aside class="docs-side">
        <nav aria-label="Docs">
          {
            nav.map((g) => (
              <div class="docs-group">
                <h4>{g.group}</h4>
                <ul>
                  {g.items.map((it) => (
                    <li>
                      <a
                        href={it.href}
                        class:list={['docs-navlink', { active: path === it.href.replace(/\/$/, '') }]}
                      >
                        {it.label}
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
            ))
          }
        </nav>
      </aside>

      <!-- content -->
      <article class="docs-main">
        <div class="docs-eyebrow">Documentation</div>
        <h1 class="docs-title serif">{title}</h1>
        <div class="prose docs-prose">
          <slot />
        </div>
        <hr class="docs-end" />
        <p class="docs-foothint">
          Something unclear or wrong?
          <a href="https://github.com/Aryan-MP/dot-context-engine/issues" target="_blank" rel="noopener">
            Open an issue
          </a>
          - docs live in <code>/docs</code> in the repo.
        </p>
      </article>

      <!-- on-page TOC -->
      <aside class="docs-toc">
        {
          toc.length > 0 && (
            <div class="docs-toc-inner">
              <h4>On this page</h4>
              <ul>
                {toc.map((h) => (
                  <li class={h.depth === 3 ? 'sub' : ''}>
                    <a href={`#${h.slug}`}>{h.text}</a>
                  </li>
                ))}
              </ul>
            </div>
          )
        }
      </aside>
    </div>
  </main>
  <Footer />

  <style>
    .docs-wrap {
      max-width: 1240px;
      margin-inline: auto;
      padding: 36px 28px 24px;
      display: grid;
      grid-template-columns: 220px minmax(0, 1fr) 200px;
      gap: 40px;
      align-items: start;
    }
    .docs-side {
      position: sticky;
      top: 84px;
    }
    .docs-group + .docs-group {
      margin-top: 22px;
    }
    .docs-group h4 {
      font-family: var(--mono);
      font-size: 10.5px;
      text-transform: uppercase;
      letter-spacing: 0.12em;
      color: var(--ink-3);
      margin-bottom: 9px;
    }
    .docs-group ul {
      list-style: none;
    }
    .docs-navlink {
      display: block;
      padding: 5px 10px;
      margin-left: -10px;
      font-size: 14.5px;
      color: var(--ink-2);
      border-radius: 3px;
      border-left: 2px solid transparent;
      transition: color 0.15s var(--easing), background 0.15s var(--easing);
    }
    .docs-navlink:hover {
      color: var(--ink);
      background: var(--paper-2);
    }
    .docs-navlink.active {
      color: var(--violet-ink);
      border-left-color: var(--violet);
      background: var(--violet-wash);
    }
    .docs-eyebrow {
      font-family: var(--mono);
      font-size: 11px;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--violet);
    }
    .docs-title {
      font-size: clamp(32px, 5vw, 46px);
      margin: 8px 0 26px;
    }
    .docs-end {
      border: none;
      border-top: 1px solid var(--rule);
      margin: 40px 0 16px;
    }
    .docs-foothint {
      font-size: 13.5px;
      color: var(--ink-3);
    }
    .docs-foothint a {
      color: var(--violet-ink);
      text-decoration: underline;
    }
    .docs-foothint code {
      font-family: var(--mono);
      font-size: 0.9em;
    }
    .docs-toc {
      position: sticky;
      top: 84px;
    }
    .docs-toc h4 {
      font-family: var(--mono);
      font-size: 10.5px;
      text-transform: uppercase;
      letter-spacing: 0.12em;
      color: var(--ink-3);
      margin-bottom: 10px;
    }
    .docs-toc ul {
      list-style: none;
      border-left: 1px solid var(--rule);
    }
    .docs-toc li a {
      display: block;
      padding: 4px 0 4px 12px;
      margin-left: -1px;
      font-size: 13px;
      color: var(--ink-3);
      border-left: 2px solid transparent;
    }
    .docs-toc li.sub a {
      padding-left: 24px;
      font-size: 12.5px;
    }
    .docs-toc li a:hover {
      color: var(--ink);
      border-left-color: var(--violet);
    }
    @media (max-width: 1080px) {
      .docs-wrap {
        grid-template-columns: 200px minmax(0, 1fr);
      }
      .docs-toc {
        display: none;
      }
    }
    @media (max-width: 760px) {
      .docs-wrap {
        grid-template-columns: 1fr;
      }
      .docs-side {
        position: static;
        border-bottom: 1px solid var(--rule);
        padding-bottom: 18px;
        margin-bottom: 8px;
      }
    }
  </style>

  <script>
    import { initReveal } from '../scripts/intersection';
    initReveal();
    // Add anchor links to headings for easy deep-linking.
    document.querySelectorAll('.docs-prose h2[id], .docs-prose h3[id]').forEach((h) => {
      const a = document.createElement('a');
      a.href = `#${h.id}`;
      a.className = 'anchor';
      a.textContent = '#';
      a.setAttribute('aria-hidden', 'true');
      h.appendChild(a);
    });
  </script>
</Base>
